{
  "info": {
    "name": "Spotify Jukebox",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://jukebox.project-prometheus.online",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Login (redirects to Spotify OAuth)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/admin/login",
              "host": ["{{base_url}}"],
              "path": ["admin", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Jukebox",
      "item": [
        {
          "name": "Currently Playing",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/juke/currently-playing",
              "host": ["{{base_url}}"],
              "path": ["juke", "currently-playing"]
            }
          }
        },
        {
          "name": "Search Tracks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/juke/search?q=bohemian rhapsody",
              "host": ["{{base_url}}"],
              "path": ["juke", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "bohemian rhapsody",
                  "description": "Search query string"
                }
              ]
            }
          }
        },
        {
          "name": "Get Queue",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/juke/queue",
              "host": ["{{base_url}}"],
              "path": ["juke", "queue"]
            }
          }
        },
        {
          "name": "Add to Queue",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/juke/queue?song_uri=spotify:track:4iV5W9uYEdYUVa79Axb7Rh",
              "host": ["{{base_url}}"],
              "path": ["juke", "queue"],
              "query": [
                {
                  "key": "song_uri",
                  "value": "spotify:track:4iV5W9uYEdYUVa79Axb7Rh",
                  "description": "Full Spotify track URI from search results"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
